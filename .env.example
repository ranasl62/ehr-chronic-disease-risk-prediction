# Copy to .env and load with your process manager (do not commit .env).
# API: optional production key (leave unset for open local dev).
API_KEY=

# Comma-separated browser origins for CORS (optional).
# CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Model artifact path (relative paths are under project root).
# MODEL_PATH=/path/to/model.pkl

# Streamlit → FastAPI: optional key matching API_KEY on the server.
# PREDICT_API_KEY=

# API hardening (optional)
# MAX_BODY_BYTES=262144
# RATE_LIMIT_PER_MINUTE=0
# AUDIT_LOG_JSONL=/var/log/ehr_api_audit.jsonl
